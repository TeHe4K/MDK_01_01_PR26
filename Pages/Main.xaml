<Page x:Class="Airlines_Коневский.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Airlines_Коневский.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid Background="#0c73fe">
        <Grid VerticalAlignment="Top">
            <TextBlock Text="Управление авиалиниями" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,10,0,10"/>
            <Button Content="Выход" Click="Exit" VerticalAlignment="Center" HorizontalAlignment="Right" Height="25" Width="100" Margin="0,0,10,0"/>
        </Grid>
        <Grid Margin="0,40,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>
            <Grid VerticalAlignment="Center" Grid.Column="1">
                <StackPanel>
            <TextBlock Text="Поиск лучших авиабилетов" Foreground="White" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10" Width="328" Grid.Column="1"/>
            <TextBlock Text="Лучший способ купить авиабилеты дёшево" Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,15,0,0" VerticalAlignment="Top" Grid.Column="1" Height="21" />
            <TextBlock Text="Откуда:" Foreground="White" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Top" Height="21" Margin="0,10,0,0" Width="55" Grid.Column="1"/>
            <TextBox Grid.Column="1" x:Name="from" VerticalAlignment="Top" Height="25" Margin="0,10,0,0" />
            <TextBlock Text="Куда:" Foreground="White" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Top" Height="21" Margin="0,10,0,0" Width="55" Grid.Column="1"/>
            <TextBox Grid.Column="1" x:Name="to" VerticalAlignment="Top" Height="25" Margin="0,10,0,0" />
                    <Button Grid.Column="1" IsDefault="True" Click="Search" VerticalAlignment="Top" HorizontalAlignment="Right" Width="100" Margin="0,10,0,0"  Content="Найти" Background="#ff4000" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
